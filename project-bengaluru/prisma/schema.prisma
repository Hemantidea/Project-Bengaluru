// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Event {
  id                    String   @id @default(uuid())
  event_type            String   // "planned" or "unplanned"
  latitude              Float
  longitude             Float
  event_cause           String   // "vehicle_breakdown", "water_logging", etc.
  vehicle_tier          String   // "Tier_1_Heavy", "Tier_2_Medium", "Tier_3_Light"
  requires_road_closure Boolean  @default(false)
  start_datetime        DateTime
  duration_minutes      Float?   // Predicted by ML
  ess_score             Float?   // Calculated Event Severity Score
  status                String   @default("active") // "active", "closed"
  createdAt             DateTime @default(now())
}

model Junction {
  id        String   @id @default(uuid())
  name      String   @unique
  latitude  Float
  longitude Float
}